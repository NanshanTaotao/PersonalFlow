# PersonalFlow local development
HOST=127.0.0.1
PORT=3000

# SQLite data location. Leave unset to use .personalflow/personalflow.sqlite.
# PERSONALFLOW_SQLITE_PATH=.personalflow/personalflow.sqlite

# Use a stable 32+ character key if you save model credentials locally.
# Do not commit a real key.
PERSONALFLOW_LOCAL_ENCRYPTION_KEY=change-me-to-a-32-character-local-key

# fake = deterministic local demo adapter
# real = use a saved OpenAI-compatible model configuration
PERSONALFLOW_MODEL_MODE=fake

# Web dev server API target.
VITE_PERSONALFLOW_API_TARGET=http://127.0.0.1:3000
